{
	"compilerOptions": {
		"paths": {
			"#client/*": ["./src/client/*"],
			"#common/*": ["./app/common/*"],
			"#core/client/*": ["./node_modules/site-core/client/*"],
			"#core/common/*": ["./node_modules/site-core/common/*"],
			"#core/config/*": ["./node_modules/site-core/config/*"],
			"#core/server/*": ["./node_modules/site-core/server/*"],
			"#core/test-helpers/*": ["./node_modules/site-core/test-helpers/*"],
			"#server/*": ["./app/server/*"]
		},
		"typeRoots": ["./node_modules/@types", "./node_modules/site-core/node_modules/@types"],
		"types": ["node"]
	},
	"extends": ["site-core/config/tsconfig.base.json", "site-core/config/tsconfig.host.json"],
	"include": [
		"app/**/*.js",
		"rolldown.config.js",
		"src/**/*.js",
		"test/**/*.js",
		"tools/**/*.js",
		"node_modules/site-core/types/index.d.ts"
	]
}
